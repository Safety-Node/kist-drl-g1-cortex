// 식탁으로 이동 — 독립 시나리오 (go_fridge.json5의 주석 참고).
{
  name: "go_table",
  triggers: ["식탁으로 가", "식탁으로", "테이블로 가", "테이블로"],
  sub_tasks: [
    {
      name: "go_table",
      on_create: [{ speak: "식탁으로 갑니다." }],
      on_start:  [{ navigation: "goal:table" }],
      // TODO(REQ-XX): uwb_pose 도착 판정으로 교체 (delay는 플레이스홀더).
      success:    { type: "delay", seconds: 25.0, timeout_s: 35.0 },
      on_success: [{ speak: "식탁에 도착했습니다." }],
      on_fail:    [{ speak: "식탁 이동에 실패했습니다." }],
    },
  ],
}

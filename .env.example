# kist-drl-g1-cortex — local credentials template.
#
# Copy to `.env` and fill in; .env is .gitignored — never commit real keys.
# Export them into the environment before launching (the nodes read os.environ
# directly; there is no config-file indirection):
#
#   set -a && source .env && set +a
#   ./scripts/run_cortex.sh

# ----------------------------------------------------------------------
# STT — Google Cloud Speech-to-Text [REQ-27] (cortex_speech/stt_node.py)
# ----------------------------------------------------------------------
# Pick ONE of the two options below. _B64 takes precedence when both are set.
#
# (A) Inline (recommended for sharing): base64-encoded service-account JSON.
#     Generate with:   base64 -w0 /path/to/service-account.json
#     stt_node decodes this in-process — no file on disk required.
GOOGLE_APPLICATION_CREDENTIALS_B64=
#
# (B) Path-based: absolute path to a GCP service-account JSON with the
#     "Cloud Speech Client" role. Auto-discovered by the Google SDK.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gcp-stt-service-account.json

# ----------------------------------------------------------------------
# TTS — Naver CLOVA Voice (Premium / TTS v1) [REQ-29] (cortex_speech/tts_node.py)
# ----------------------------------------------------------------------
# Obtain from NCP Console → AI·NAVER API → CLOVA Voice → 인증 정보.
# Env var names are overridable via TTSConfig.client_id_env / client_secret_env.
NCP_CLOVA_CLIENT_ID=
NCP_CLOVA_CLIENT_SECRET=

# ----------------------------------------------------------------------
# DDS peer (optional) — env.sh defaults DDS_PEER_IP to the NX (192.168.123.164).
# Override here if the demo LAN differs.
# ----------------------------------------------------------------------
DDS_PEER_IP=

<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">

  <!--
    Bridge domain shared with the NX onboard stack (Domain Id=1).
    Must stay in sync with kist-drl-g1-onboard/config/cyclonedds.xml.

    Unicast-only peer discovery: multicast is off, the NX is listed as an
    explicit peer. DDS_PEER_IP must resolve to the NX before launch (see env.sh).

    TODO(REQ-XX): confirm the PC NIC name below on the demo machine
    (`ip -br link`). It is host-specific and NOT portable.
  -->
  <Domain Id="1">
    <General>
      <Interfaces>
        <!-- PC NIC facing the robot LAN. Change to match the demo machine. -->
        <NetworkInterface name="eno2" priority="default" multicast="false"/>
        <NetworkInterface name="lo"   priority="default" multicast="false"/>
      </Interfaces>
      <AllowMulticast>false</AllowMulticast>
      <MaxMessageSize>65500B</MaxMessageSize>
    </General>
    <Discovery>
      <Peers>
        <Peer address="localhost"/>
        <Peer address="${DDS_PEER_IP}"/>
      </Peers>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>20</MaxAutoParticipantIndex>
      <EnableTopicDiscoveryEndpoints>true</EnableTopicDiscoveryEndpoints>
    </Discovery>
    <Internal>
      <Watermarks>
        <WhcHigh>2MB</WhcHigh>
      </Watermarks>
    </Internal>
    <Tracing>
      <Verbosity>warning</Verbosity>
      <OutputFile>stderr</OutputFile>
    </Tracing>
  </Domain>

</CycloneDDS>
